Mordle.app/Contents/PkgInfo: 
	@test -d Mordle.app/Contents || mkdir -p Mordle.app/Contents
	@$(DEL_FILE) Mordle.app/Contents/PkgInfo
	@echo "APPL????" > Mordle.app/Contents/PkgInfo
Mordle.app/Contents/Info.plist: 
	@test -d Mordle.app/Contents || mkdir -p Mordle.app/Contents
	@$(DEL_FILE) Mordle.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - ../../../../Qt/6.10.2/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,t.Mordle,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},t.Mordle,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,Mordle,g" -e "s,@LIBRARY@,Mordle,g" -e "s,\$${EXECUTABLE_NAME},Mordle,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >Mordle.app/Contents/Info.plist

all: Makefile \
		Mordle.app/Contents/PkgInfo \
		Mordle.app/Contents/Info.plist Mordle.app/Contents/MacOS/Mordle

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../resources.qrc $(DISTDIR)/
	$(COPY_FILE) --parents ../../game.h ../../mainmenu.h ../../mainwindow.h ../../settings.h ../../summary.h ../../tile.h $(DISTDIR)/
	$(COPY_FILE) --parents ../../game.cpp ../../main.cpp ../../mainmenu.cpp ../../mainwindow.cpp ../../settings.cpp ../../summary.cpp ../../tile.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../game.ui ../../mainmenu.ui ../../mainwindow.ui ../../settings.ui ../../summary.ui $(DISTDIR)/


clean: compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


