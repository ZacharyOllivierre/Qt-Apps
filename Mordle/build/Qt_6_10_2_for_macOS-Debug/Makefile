####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/Mordle/bin || mkdir -p $(INSTALL_ROOT)/opt/Mordle/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/Mordle/bin/Mordle.app
	
	$(QINSTALL) Mordle.app $(INSTALL_ROOT)/opt/Mordle/bin/Mordle.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/Mordle/bin/Mordle.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/Mordle/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

